#!/bin/bash

COMPOSE_FILE="/root/MRSSH/docker-compose.yml"

show_status() {
    echo "=================================="
    echo "      MRSSH Status & Health"
    echo "=================================="
    echo

    PANEL_URL="http://$(curl -4 -s https://api.ipify.org 2>/dev/null || hostname -I | awk '{print $1}'):8080"
    SSH_PORT=$(sshd -T 2>/dev/null | awk '/^port /{print $2; exit}')
    SSH_PORT=${SSH_PORT:-22}

    echo "Panel URL: $PANEL_URL"
    echo "SSH Port:  $SSH_PORT"
    echo

    echo "Services:"
    systemctl is-active --quiet ssh && echo "  SSH:       OK" || echo "  SSH:       FAILED"
    systemctl is-active --quiet nginx && echo "  Nginx:     OK" || echo "  Nginx:     FAILED"
    systemctl is-active --quiet fail2ban && echo "  Fail2Ban:  OK" || echo "  Fail2Ban:  FAILED"
    systemctl is-active --quiet mrssh-agent && echo "  Agent:     OK" || echo "  Agent:     FAILED"
    systemctl is-active --quiet mrssh-traffic && echo "  Traffic:   OK" || echo "  Traffic:   FAILED"

    UDPGW_PORT=$(sqlite3 /opt/mrssh-agent/mrssh.db "select value from settings where key='udpgwPort';" 2>/dev/null | head -1)
    UDPGW_PORT=${UDPGW_PORT:-7301}

    if systemctl is-active --quiet mrssh-udpgw; then
        echo "  UDPGW:     OK ($UDPGW_PORT)"
    else
        echo "  UDPGW:     NOT INSTALLED ($UDPGW_PORT)"
    fi

    echo

    echo "API:"
    curl -fsS http://127.0.0.1:8080/api/health >/dev/null && echo "  Panel API: OK" || echo "  Panel API: FAILED"
    curl -fsS http://127.0.0.1:8000/health >/dev/null && echo "  Backend:   OK" || echo "  Backend:   FAILED"

    ENV_FILE=""
    [ -f /opt/mrssh-agent/.env ] && ENV_FILE="/opt/mrssh-agent/.env"
    [ -z "$ENV_FILE" ] && [ -f /opt/mrssh/.env ] && ENV_FILE="/opt/mrssh/.env"

    if [ -n "$ENV_FILE" ]; then
        SECRET=$(grep '^MRSSH_SECRET=' "$ENV_FILE" | cut -d= -f2-)
        curl -fsS -H "X-Secret: $SECRET" http://127.0.0.1:9911/dashboard >/dev/null && echo "  Agent API: OK" || echo "  Agent API: FAILED"
    else
        echo "  Agent API: FAILED (.env missing)"
    fi

    echo
    echo "Firewall:"
    PANEL_PORT=$(grep '^MRSSH_WEB_BIND=' /opt/mrssh/.env 2>/dev/null | cut -d= -f2- | awk -F: '{print $NF}')
    PANEL_PORT=${PANEL_PORT:-8080}

    ufw status | grep -Eq "^${SSH_PORT}(/tcp)?[[:space:]]+ALLOW" && echo "  SSH Port:  OPEN" || echo "  SSH Port:  CHECK"
    ufw status | grep -Eq "^${PANEL_PORT}(/tcp)?[[:space:]]+ALLOW" && echo "  Panel:     OPEN ($PANEL_PORT)" || echo "  Panel:     CHECK ($PANEL_PORT)"
    ufw status | grep -Eq "^80(/tcp)?[[:space:]]+ALLOW" && echo "  HTTP:      OPEN" || echo "  HTTP:      CHECK"
    ufw status | grep -Eq "^443(/tcp)?[[:space:]]+ALLOW" && echo "  HTTPS:     OPEN" || echo "  HTTPS:     CHECK"

    echo
    echo "System:"
    echo "  Load:      $(cat /proc/loadavg | awk '{print $1, $2, $3}')"
    echo "  RAM:       $(free -m | awk '/Mem:/ {print $3 "MB / " $2 "MB"}')"
    echo "  Disk:      $(df -h / | awk 'NR==2 {print $3 " / " $2 " (" $5 ")"}')"
    echo "  Uptime:    $(uptime -p)"
    echo

    if [ -f /opt/mrssh-agent/mrssh.db ]; then
        USERS=$(sqlite3 /opt/mrssh-agent/mrssh.db "select count(*) from users_meta;" 2>/dev/null || echo 0)
        echo "MRSSH:"
        echo "  Tracked Users: $USERS"
    fi

    echo
    echo "Health check completed"
}

install_ssl() {
    read -p "Domain: " DOMAIN
    read -p "Email: " EMAIL

    if [ -z "$DOMAIN" ] || [ -z "$EMAIL" ]; then
        echo "Domain and email are required"
        return
    fi

    echo "[SSL] Configuring Nginx for $DOMAIN..."

    cat > /etc/nginx/sites-available/mrssh <<EOFNGINX
server {
    listen 80;
    server_name $DOMAIN;

    root /var/www/mrssh;
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_connect_timeout 3s;
        proxy_read_timeout 30s;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location / {
        try_files \$uri /index.html;
    }
}
EOFNGINX

    ln -sf /etc/nginx/sites-available/mrssh /etc/nginx/sites-enabled/mrssh
    nginx -t || { echo "Nginx config failed"; return; }
    systemctl reload nginx

    certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos -m "$EMAIL" || {
        echo "Certbot failed"
        return
    }

    echo
    echo "SSL done:"
    echo "https://$DOMAIN"
}

restart_services() {
    systemctl restart mrssh-agent
    systemctl restart mrssh-traffic mrssh-limiter mrssh-expire mrssh-enforce 2>/dev/null || true

    if [ -f "$COMPOSE_FILE" ]; then
        docker compose -f "$COMPOSE_FILE" restart backend
    fi

    systemctl reload nginx
    echo "Services restarted"
}

show_admin_info() {
    if [ -f /opt/mrssh/.env ]; then
        grep -E '^(ADMIN_USERNAME|ADMIN_PASSWORD|MRSSH_WEB_BIND)=' /opt/mrssh/.env
    else
        echo "/opt/mrssh/.env not found"
    fi
}



change_ssh_port() {
    CUR=$(sshd -T 2>/dev/null | awk '/^port /{print $2; exit}')
    CUR=${CUR:-22}

    echo "Current SSH Port: $CUR"
    echo "Enter new SSH port, or type b to go back"
    read -p "New SSH Port: " NEW

    if [ "$NEW" = "b" ] || [ "$NEW" = "B" ]; then
        echo "Cancelled"
        return
    fi

    if ! echo "$NEW" | grep -Eq '^[0-9]+$'; then
        echo "Invalid port"
        return
    fi

    if [ "$NEW" -lt 1 ] || [ "$NEW" -gt 65535 ]; then
        echo "Port out of range"
        return
    fi

    ufw allow ${NEW}/tcp

    cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak

    if grep -q '^Port ' /etc/ssh/sshd_config; then
        sed -i "s/^Port .*/Port ${NEW}/" /etc/ssh/sshd_config
    else
        echo "Port ${NEW}" >> /etc/ssh/sshd_config
    fi

    sshd -t || {
        echo "Invalid SSH config"
        cp /etc/ssh/sshd_config.bak /etc/ssh/sshd_config
        return
    }

    systemctl restart ssh

    sleep 2

    if ss -tulpn | grep -q ":${NEW} "; then
        echo "SSH port changed to ${NEW}"

        read -p "Remove old firewall port ${CUR}? (y/N): " A

        if [ "$A" = "y" ] || [ "$A" = "Y" ]; then
            ufw delete allow ${CUR}/tcp
        fi
    else
        echo "SSH failed, rolling back"
        cp /etc/ssh/sshd_config.bak /etc/ssh/sshd_config
        systemctl restart ssh
    fi
}



update_mrssh() {
    APP_DIR="/root/MRSSH"

    if [ ! -d "$APP_DIR/.git" ]; then
        echo "MRSSH git repo not found at $APP_DIR"
        return
    fi

    echo "[UPDATE] Pulling latest code..."
    cd "$APP_DIR" || return

    git pull || {
        echo "git pull failed"
        return
    }

    echo "[UPDATE] Copying agent files..."
    mkdir -p /opt/mrssh-agent
    cp -r "$APP_DIR/installer/agent/"* /opt/mrssh-agent/

    echo "[UPDATE] Installing mrssh command..."
    install -m 755 "$APP_DIR/installer/bin/mrssh" /usr/local/bin/mrssh

    echo "[UPDATE] Rebuilding backend..."
    docker compose -f "$APP_DIR/docker-compose.yml" build backend || {
        echo "Docker build failed"
        return
    }

    docker compose -f "$APP_DIR/docker-compose.yml" up -d backend || {
        echo "Backend restart failed"
        return
    }

    echo "[UPDATE] Rebuilding frontend..."
    docker build -t mrssh-frontend-static "$APP_DIR/frontend" || {
        echo "Frontend build failed"
        return
    }

    rm -rf /var/www/mrssh
    mkdir -p /var/www/mrssh

    docker rm -f mrssh-front-tmp >/dev/null 2>&1 || true
    docker create --name mrssh-front-tmp mrssh-frontend-static >/dev/null
    docker cp mrssh-front-tmp:/usr/share/nginx/html/. /var/www/mrssh/
    docker rm mrssh-front-tmp >/dev/null

    echo "[UPDATE] Restarting services..."
    systemctl restart mrssh-agent mrssh-traffic mrssh-limiter mrssh-expire mrssh-enforce 2>/dev/null || true
    systemctl reload nginx

    echo "[CHECK] API..."
    sleep 3
    curl -fsS http://127.0.0.1:8080/api/health >/dev/null || {
        echo "API health failed"
        return
    }

    echo
    echo "MRSSH updated successfully"
}



backup_mrssh() {
    BACKUP_DIR="/root/mrssh-backups"
    mkdir -p "$BACKUP_DIR"

    FILE="$BACKUP_DIR/mrssh-backup-$(date +%F-%H%M%S).tar.gz"

    tar -czf "$FILE" \
        /opt/mrssh/.env \
        /opt/mrssh-agent/mrssh.db \
        /etc/nginx/sites-available/mrssh \
        /etc/ssh/sshd_config 2>/dev/null

    echo
    echo "Backup created:"
    echo "$FILE"
}

restore_mrssh() {
    BACKUP_DIR="/root/mrssh-backups"

    mapfile -t FILES < <(find "$BACKUP_DIR" -maxdepth 1 -type f -name "*.tar.gz" | sort -r)

    if [ ${#FILES[@]} -eq 0 ]; then
        echo "No backups found"
        return
    fi

    echo
    echo "Available Backups"
    echo "-----------------"

    i=1
    for f in "${FILES[@]}"; do
        SIZE=$(du -h "$f" | awk '{print $1}')
        DATE=$(date -r "$f" "+%Y-%m-%d %H:%M:%S")
        echo "$i) $(basename "$f") [$SIZE] [$DATE]"
        i=$((i+1))
    done

    echo
    echo "0) Back"
    echo

    read -p "Select backup: " IDX

    if [ "$IDX" = "0" ]; then
        echo "Cancelled"
        return
    fi

    if ! echo "$IDX" | grep -Eq '^[0-9]+$'; then
        echo "Invalid selection"
        return
    fi

    IDX=$((IDX-1))

    if [ "$IDX" -lt 0 ] || [ "$IDX" -ge "${#FILES[@]}" ]; then
        echo "Invalid selection"
        return
    fi

    FILE="${FILES[$IDX]}"

    echo
    echo "Selected:"
    echo "$(basename "$FILE")"
    echo

    read -p "Restore this backup? (y/N): " A

    if [ "$A" != "y" ] && [ "$A" != "Y" ]; then
        echo "Cancelled"
        return
    fi

    tar -xzf "$FILE" -C /

    systemctl restart mrssh-agent 2>/dev/null || true
    systemctl restart ssh 2>/dev/null || true
    systemctl reload nginx 2>/dev/null || true

    echo
    echo "Restore completed"
}



change_admin_password() {
    read -s -p "New admin password: " PASS1
    echo
    read -s -p "Confirm password: " PASS2
    echo

    if [ -z "$PASS1" ]; then
        echo "Password cannot be empty"
        return
    fi

    if [ "$PASS1" != "$PASS2" ]; then
        echo "Passwords do not match"
        return
    fi

    ADMIN_PASS="$PASS1" python3 - <<'PYADMIN'
import os, sqlite3, hashlib, secrets, time

DB="/opt/mrssh-agent/mrssh.db"
password=os.environ["ADMIN_PASS"]

salt=secrets.token_hex(16)
password_hash=hashlib.sha256((salt+password).encode()).hexdigest()

con=sqlite3.connect(DB)
con.execute("""
CREATE TABLE IF NOT EXISTS admin_auth (
  username TEXT PRIMARY KEY,
  password_hash TEXT NOT NULL,
  salt TEXT NOT NULL,
  updated_at INTEGER NOT NULL
)
""")
con.execute("""
INSERT INTO admin_auth(username,password_hash,salt,updated_at)
VALUES('admin',?,?,?)
ON CONFLICT(username) DO UPDATE SET
  password_hash=excluded.password_hash,
  salt=excluded.salt,
  updated_at=excluded.updated_at
""", (password_hash, salt, int(time.time())))
con.commit()
con.close()
PYADMIN

    if [ -f /opt/mrssh/.env ]; then
        sed -i "s/^ADMIN_PASSWORD=.*/ADMIN_PASSWORD=$PASS1/" /opt/mrssh/.env
    fi

    if [ -f /opt/mrssh-agent/.env ]; then
        sed -i "s/^ADMIN_PASSWORD=.*/ADMIN_PASSWORD=$PASS1/" /opt/mrssh-agent/.env
    fi

    if [ -f /root/MRSSH/docker-compose.yml ]; then
        docker compose -f /root/MRSSH/docker-compose.yml restart backend >/dev/null 2>&1 || true
    fi

    systemctl restart mrssh-agent 2>/dev/null || true

    echo
    echo "Admin password updated successfully"
}



get_udpgw_port() {
    sqlite3 /opt/mrssh-agent/mrssh.db "select value from settings where key='udpgwPort';" 2>/dev/null | head -1
}

install_udpgw() {
    PORT=$(get_udpgw_port)
    PORT=${PORT:-7301}

    echo "UDPGW Port: $PORT"
    read -p "Use this port? (Y/n): " A

    if [ "$A" = "n" ] || [ "$A" = "N" ]; then
        read -p "New UDPGW Port [7301]: " PORT
        PORT=${PORT:-7301}
    fi

    if ! echo "$PORT" | grep -Eq '^[0-9]+$'; then
        echo "Invalid port"
        return
    fi

    if [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
        echo "Port out of range"
        return
    fi

    echo "[UDPGW] Installing dependencies..."
    apt-get update
    apt-get install -y build-essential cmake git

    TMP="/tmp/badvpn-build"
    rm -rf "$TMP"
    git clone https://github.com/ambrop72/badvpn.git "$TMP" || {
        echo "Failed to clone badvpn"
        return
    }

    mkdir -p "$TMP/build"
    cd "$TMP/build" || return

    cmake .. -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1 || {
        echo "cmake failed"
        return
    }

    make -j"$(nproc)" || {
        echo "build failed"
        return
    }

    install -m 755 udpgw/badvpn-udpgw /usr/local/bin/badvpn-udpgw

    cat > /etc/systemd/system/mrssh-udpgw.service <<EOFSVC
[Unit]
Description=MRSSH BadVPN UDPGW
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/badvpn-udpgw --listen-addr 0.0.0.0:$PORT --max-clients 4096 --max-connections-for-client 256
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
EOFSVC

    ufw allow "$PORT/tcp" || true
    ufw allow "$PORT/udp" || true

    sqlite3 /opt/mrssh-agent/mrssh.db "
    CREATE TABLE IF NOT EXISTS settings (key TEXT PRIMARY KEY, value TEXT);
    INSERT INTO settings(key,value) VALUES('udpgwPort','$PORT')
    ON CONFLICT(key) DO UPDATE SET value=excluded.value;
    "

    systemctl daemon-reload
    systemctl enable --now mrssh-udpgw
    systemctl restart mrssh-udpgw

    echo
    systemctl status mrssh-udpgw --no-pager -l
    echo
    echo "UDPGW installed:"
    echo "Port: $PORT/udp"
}

while true; do
    clear

    echo "=================================="
    echo "           MRSSH MENU"
    echo "=================================="
    echo
    echo "1) Show Status & Health Check"
    echo "2) Install SSL"
    echo "3) Restart Services"
    echo "4) Show Admin Info"
    echo "5) Firewall Status"
    echo "6) Change SSH Port"
    echo "7) Update MRSSH"
    echo "8) Backup MRSSH"
    echo "9) Restore Backup"
    echo "10) Change Admin Password"
    echo "11) Install/Restart UDPGW"
    echo "0) Exit"
    echo

    read -p "Select: " opt

    case "$opt" in
        1) show_status ;;
        2) install_ssl ;;
        3) restart_services ;;
        4) show_admin_info ;;
        5) ufw status ;;
        6) change_ssh_port ;;
        7) update_mrssh ;;
        8) backup_mrssh ;;
        9) restore_mrssh ;;
        10) change_admin_password ;;
        11) install_udpgw ;;
        0) exit 0 ;;
        *) echo "Invalid option" ;;
    esac

    echo
    read -p "Press Enter..."
done
