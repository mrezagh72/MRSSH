#!/bin/bash

COMPOSE_FILE="/root/MRSSH/docker-compose.yml"

show_status() {
    echo "=== MRSSH Status ==="
    echo
    systemctl is-active --quiet mrssh-agent && echo "Agent: active" || echo "Agent: inactive"
    systemctl is-active --quiet fail2ban && echo "Fail2Ban: active" || echo "Fail2Ban: inactive"
    systemctl is-active --quiet nginx && echo "Nginx: active" || echo "Nginx: inactive"
    echo
    curl -fsS http://127.0.0.1:8080/api/health >/dev/null && echo "Panel API: OK" || echo "Panel API: FAILED"
}

install_ssl() {
    read -p "Domain: " DOMAIN
    read -p "Email: " EMAIL

    if [ -z "$DOMAIN" ] || [ -z "$EMAIL" ]; then
        echo "Domain and email are required"
        return
    fi

    echo "[SSL] Configuring Nginx for $DOMAIN..."

    cat > /etc/nginx/sites-available/mrssh <<EOFNGINX
server {
    listen 80;
    server_name $DOMAIN;

    root /var/www/mrssh;
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_connect_timeout 3s;
        proxy_read_timeout 30s;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location / {
        try_files \$uri /index.html;
    }
}
EOFNGINX

    ln -sf /etc/nginx/sites-available/mrssh /etc/nginx/sites-enabled/mrssh
    nginx -t || { echo "Nginx config failed"; return; }
    systemctl reload nginx

    certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos -m "$EMAIL" || {
        echo "Certbot failed"
        return
    }

    echo
    echo "SSL done:"
    echo "https://$DOMAIN"
}

restart_services() {
    systemctl restart mrssh-agent
    systemctl restart mrssh-traffic mrssh-limiter mrssh-expire mrssh-enforce 2>/dev/null || true

    if [ -f "$COMPOSE_FILE" ]; then
        docker compose -f "$COMPOSE_FILE" restart backend
    fi

    systemctl reload nginx
    echo "Services restarted"
}

show_admin_info() {
    if [ -f /opt/mrssh/.env ]; then
        grep -E '^(ADMIN_USERNAME|ADMIN_PASSWORD|MRSSH_WEB_BIND)=' /opt/mrssh/.env
    else
        echo "/opt/mrssh/.env not found"
    fi
}



change_ssh_port() {
    CUR=$(sshd -T 2>/dev/null | awk '/^port /{print $2; exit}')
    CUR=${CUR:-22}

    echo "Current SSH Port: $CUR"
    echo "Enter new SSH port, or type b to go back"
    read -p "New SSH Port: " NEW

    if [ "$NEW" = "b" ] || [ "$NEW" = "B" ]; then
        echo "Cancelled"
        return
    fi

    if ! echo "$NEW" | grep -Eq '^[0-9]+$'; then
        echo "Invalid port"
        return
    fi

    if [ "$NEW" -lt 1 ] || [ "$NEW" -gt 65535 ]; then
        echo "Port out of range"
        return
    fi

    ufw allow ${NEW}/tcp

    cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak

    if grep -q '^Port ' /etc/ssh/sshd_config; then
        sed -i "s/^Port .*/Port ${NEW}/" /etc/ssh/sshd_config
    else
        echo "Port ${NEW}" >> /etc/ssh/sshd_config
    fi

    sshd -t || {
        echo "Invalid SSH config"
        cp /etc/ssh/sshd_config.bak /etc/ssh/sshd_config
        return
    }

    systemctl restart ssh

    sleep 2

    if ss -tulpn | grep -q ":${NEW} "; then
        echo "SSH port changed to ${NEW}"

        read -p "Remove old firewall port ${CUR}? (y/N): " A

        if [ "$A" = "y" ] || [ "$A" = "Y" ]; then
            ufw delete allow ${CUR}/tcp
        fi
    else
        echo "SSH failed, rolling back"
        cp /etc/ssh/sshd_config.bak /etc/ssh/sshd_config
        systemctl restart ssh
    fi
}



update_mrssh() {
    APP_DIR="/root/MRSSH"

    if [ ! -d "$APP_DIR/.git" ]; then
        echo "MRSSH git repo not found at $APP_DIR"
        return
    fi

    echo "[UPDATE] Pulling latest code..."
    cd "$APP_DIR" || return

    git pull || {
        echo "git pull failed"
        return
    }

    echo "[UPDATE] Copying agent files..."
    mkdir -p /opt/mrssh-agent
    cp -r "$APP_DIR/installer/agent/"* /opt/mrssh-agent/

    echo "[UPDATE] Installing mrssh command..."
    install -m 755 "$APP_DIR/installer/bin/mrssh" /usr/local/bin/mrssh

    echo "[UPDATE] Rebuilding backend..."
    docker compose -f "$APP_DIR/docker-compose.yml" build backend || {
        echo "Docker build failed"
        return
    }

    docker compose -f "$APP_DIR/docker-compose.yml" up -d backend || {
        echo "Backend restart failed"
        return
    }

    echo "[UPDATE] Rebuilding frontend..."
    docker build -t mrssh-frontend-static "$APP_DIR/frontend" || {
        echo "Frontend build failed"
        return
    }

    rm -rf /var/www/mrssh
    mkdir -p /var/www/mrssh

    docker rm -f mrssh-front-tmp >/dev/null 2>&1 || true
    docker create --name mrssh-front-tmp mrssh-frontend-static >/dev/null
    docker cp mrssh-front-tmp:/usr/share/nginx/html/. /var/www/mrssh/
    docker rm mrssh-front-tmp >/dev/null

    echo "[UPDATE] Restarting services..."
    systemctl restart mrssh-agent mrssh-traffic mrssh-limiter mrssh-expire mrssh-enforce 2>/dev/null || true
    systemctl reload nginx

    echo "[CHECK] API..."
    sleep 3
    curl -fsS http://127.0.0.1:8080/api/health >/dev/null || {
        echo "API health failed"
        return
    }

    echo
    echo "MRSSH updated successfully"
}



backup_mrssh() {
    BACKUP_DIR="/root/mrssh-backups"
    mkdir -p "$BACKUP_DIR"

    FILE="$BACKUP_DIR/mrssh-backup-$(date +%F-%H%M%S).tar.gz"

    tar -czf "$FILE" \
        /opt/mrssh/.env \
        /opt/mrssh-agent/mrssh.db \
        /etc/nginx/sites-available/mrssh \
        /etc/ssh/sshd_config 2>/dev/null

    echo
    echo "Backup created:"
    echo "$FILE"
}

restore_mrssh() {
    BACKUP_DIR="/root/mrssh-backups"

    mapfile -t FILES < <(find "$BACKUP_DIR" -maxdepth 1 -type f -name "*.tar.gz" | sort -r)

    if [ ${#FILES[@]} -eq 0 ]; then
        echo "No backups found"
        return
    fi

    echo
    echo "Available Backups"
    echo "-----------------"

    i=1
    for f in "${FILES[@]}"; do
        SIZE=$(du -h "$f" | awk '{print $1}')
        DATE=$(date -r "$f" "+%Y-%m-%d %H:%M:%S")
        echo "$i) $(basename "$f") [$SIZE] [$DATE]"
        i=$((i+1))
    done

    echo
    echo "0) Back"
    echo

    read -p "Select backup: " IDX

    if [ "$IDX" = "0" ]; then
        echo "Cancelled"
        return
    fi

    if ! echo "$IDX" | grep -Eq '^[0-9]+$'; then
        echo "Invalid selection"
        return
    fi

    IDX=$((IDX-1))

    if [ "$IDX" -lt 0 ] || [ "$IDX" -ge "${#FILES[@]}" ]; then
        echo "Invalid selection"
        return
    fi

    FILE="${FILES[$IDX]}"

    echo
    echo "Selected:"
    echo "$(basename "$FILE")"
    echo

    read -p "Restore this backup? (y/N): " A

    if [ "$A" != "y" ] && [ "$A" != "Y" ]; then
        echo "Cancelled"
        return
    fi

    tar -xzf "$FILE" -C /

    systemctl restart mrssh-agent 2>/dev/null || true
    systemctl restart ssh 2>/dev/null || true
    systemctl reload nginx 2>/dev/null || true

    echo
    echo "Restore completed"
}



change_admin_password() {
    read -s -p "New admin password: " PASS1
    echo
    read -s -p "Confirm password: " PASS2
    echo

    if [ -z "$PASS1" ]; then
        echo "Password cannot be empty"
        return
    fi

    if [ "$PASS1" != "$PASS2" ]; then
        echo "Passwords do not match"
        return
    fi

    ADMIN_PASS="$PASS1" python3 - <<'PYADMIN'
import os, sqlite3, hashlib, secrets, time

DB="/opt/mrssh-agent/mrssh.db"
password=os.environ["ADMIN_PASS"]

salt=secrets.token_hex(16)
password_hash=hashlib.sha256((salt+password).encode()).hexdigest()

con=sqlite3.connect(DB)
con.execute("""
CREATE TABLE IF NOT EXISTS admin_auth (
  username TEXT PRIMARY KEY,
  password_hash TEXT NOT NULL,
  salt TEXT NOT NULL,
  updated_at INTEGER NOT NULL
)
""")
con.execute("""
INSERT INTO admin_auth(username,password_hash,salt,updated_at)
VALUES('admin',?,?,?)
ON CONFLICT(username) DO UPDATE SET
  password_hash=excluded.password_hash,
  salt=excluded.salt,
  updated_at=excluded.updated_at
""", (password_hash, salt, int(time.time())))
con.commit()
con.close()
PYADMIN

    if [ -f /opt/mrssh/.env ]; then
        sed -i "s/^ADMIN_PASSWORD=.*/ADMIN_PASSWORD=$PASS1/" /opt/mrssh/.env
    fi

    if [ -f /opt/mrssh-agent/.env ]; then
        sed -i "s/^ADMIN_PASSWORD=.*/ADMIN_PASSWORD=$PASS1/" /opt/mrssh-agent/.env
    fi

    if [ -f /root/MRSSH/docker-compose.yml ]; then
        docker compose -f /root/MRSSH/docker-compose.yml restart backend >/dev/null 2>&1 || true
    fi

    systemctl restart mrssh-agent 2>/dev/null || true

    echo
    echo "Admin password updated successfully"
}

while true; do
    clear

    echo "=================================="
    echo "           MRSSH MENU"
    echo "=================================="
    echo
    echo "1) Show Status"
    echo "2) Install SSL"
    echo "3) Restart Services"
    echo "4) Show Admin Info"
    echo "5) Firewall Status"
    echo "6) Change SSH Port"
    echo "7) Update MRSSH"
    echo "8) Backup MRSSH"
    echo "9) Restore Backup"
    echo "10) Change Admin Password"
    echo "0) Exit"
    echo

    read -p "Select: " opt

    case "$opt" in
        1) show_status ;;
        2) install_ssl ;;
        3) restart_services ;;
        4) show_admin_info ;;
        5) ufw status ;;
        6) change_ssh_port ;;
        7) update_mrssh ;;
        8) backup_mrssh ;;
        9) restore_mrssh ;;
        10) change_admin_password ;;
        0) exit 0 ;;
        *) echo "Invalid option" ;;
    esac

    echo
    read -p "Press Enter..."
done
