#!/bin/bash

COMPOSE_FILE="/root/MRSSH/docker-compose.yml"

show_status() {
    echo "=== MRSSH Status ==="
    echo
    systemctl is-active --quiet mrssh-agent && echo "Agent: active" || echo "Agent: inactive"
    systemctl is-active --quiet fail2ban && echo "Fail2Ban: active" || echo "Fail2Ban: inactive"
    systemctl is-active --quiet nginx && echo "Nginx: active" || echo "Nginx: inactive"
    echo
    curl -fsS http://127.0.0.1:8080/api/health >/dev/null && echo "Panel API: OK" || echo "Panel API: FAILED"
}

install_ssl() {
    read -p "Domain: " DOMAIN
    read -p "Email: " EMAIL

    if [ -z "$DOMAIN" ] || [ -z "$EMAIL" ]; then
        echo "Domain and email are required"
        return
    fi

    echo "[SSL] Configuring Nginx for $DOMAIN..."

    cat > /etc/nginx/sites-available/mrssh <<EOFNGINX
server {
    listen 80;
    server_name $DOMAIN;

    root /var/www/mrssh;
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_connect_timeout 3s;
        proxy_read_timeout 30s;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location / {
        try_files \$uri /index.html;
    }
}
EOFNGINX

    ln -sf /etc/nginx/sites-available/mrssh /etc/nginx/sites-enabled/mrssh
    nginx -t || { echo "Nginx config failed"; return; }
    systemctl reload nginx

    certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos -m "$EMAIL" || {
        echo "Certbot failed"
        return
    }

    echo
    echo "SSL done:"
    echo "https://$DOMAIN"
}

restart_services() {
    systemctl restart mrssh-agent
    systemctl restart mrssh-traffic mrssh-limiter mrssh-expire mrssh-enforce 2>/dev/null || true

    if [ -f "$COMPOSE_FILE" ]; then
        docker compose -f "$COMPOSE_FILE" restart backend
    fi

    systemctl reload nginx
    echo "Services restarted"
}

show_admin_info() {
    if [ -f /opt/mrssh/.env ]; then
        grep -E '^(ADMIN_USERNAME|ADMIN_PASSWORD|MRSSH_WEB_BIND)=' /opt/mrssh/.env
    else
        echo "/opt/mrssh/.env not found"
    fi
}



change_ssh_port() {
    CUR=$(sshd -T 2>/dev/null | awk '/^port /{print $2; exit}')
    CUR=${CUR:-22}

    echo "Current SSH Port: $CUR"
    echo "Enter new SSH port, or type b to go back"
    read -p "New SSH Port: " NEW

    if [ "$NEW" = "b" ] || [ "$NEW" = "B" ]; then
        echo "Cancelled"
        return
    fi

    if ! echo "$NEW" | grep -Eq '^[0-9]+$'; then
        echo "Invalid port"
        return
    fi

    if [ "$NEW" -lt 1 ] || [ "$NEW" -gt 65535 ]; then
        echo "Port out of range"
        return
    fi

    ufw allow ${NEW}/tcp

    cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak

    if grep -q '^Port ' /etc/ssh/sshd_config; then
        sed -i "s/^Port .*/Port ${NEW}/" /etc/ssh/sshd_config
    else
        echo "Port ${NEW}" >> /etc/ssh/sshd_config
    fi

    sshd -t || {
        echo "Invalid SSH config"
        cp /etc/ssh/sshd_config.bak /etc/ssh/sshd_config
        return
    }

    systemctl restart ssh

    sleep 2

    if ss -tulpn | grep -q ":${NEW} "; then
        echo "SSH port changed to ${NEW}"

        read -p "Remove old firewall port ${CUR}? (y/N): " A

        if [ "$A" = "y" ] || [ "$A" = "Y" ]; then
            ufw delete allow ${CUR}/tcp
        fi
    else
        echo "SSH failed, rolling back"
        cp /etc/ssh/sshd_config.bak /etc/ssh/sshd_config
        systemctl restart ssh
    fi
}

while true; do
    clear

    echo "=================================="
    echo "           MRSSH MENU"
    echo "=================================="
    echo
    echo "1) Show Status"
    echo "2) Install SSL"
    echo "3) Restart Services"
    echo "4) Show Admin Info"
    echo "5) Firewall Status"
    echo "6) Change SSH Port"
    echo "0) Exit"
    echo

    read -p "Select: " opt

    case "$opt" in
        1) show_status ;;
        2) install_ssl ;;
        3) restart_services ;;
        4) show_admin_info ;;
        5) ufw status ;;
        6) change_ssh_port ;;
        0) exit 0 ;;
        *) echo "Invalid option" ;;
    esac

    echo
    read -p "Press Enter..."
done
